---
import { useTranslations, getLocale } from "../../i18n/utils";
import {
  githubUrl,
  linkedinUrl,
  mediumUrl,
  meetingUrl,
  scholarUrl,
} from "../../data/links";

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);

const year = new Date().getFullYear();

const socialLinks = [
  {
    label: "GitHub",
    href: githubUrl,
    icon: "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.333-1.754-1.333-1.754-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.418-1.305.762-1.605-2.665-.305-5.466-1.334-5.466-5.93 0-1.31.467-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12",
  },
  {
    label: "LinkedIn",
    href: linkedinUrl,
    icon: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  {
    label: "Google Scholar",
    href: scholarUrl,
    icon: "M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z",
  },
  {
    label: "Medium",
    href: mediumUrl,
    icon: "M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z",
    // Medium's glyph only fills the middle ~57% of its 24x24 viewBox vertically, so
    // scale it up to visually match the full-bleed GitHub/LinkedIn marks. The wrapper
    // grows to match, keeping the gap to neighboring icons even.
    iconClass: "scale-150",
    wrapperClass: "h-6 w-6",
  },
  {
    label: "Meet",
    href: meetingUrl,
    icon: "M4.5 4.5a3 3 0 0 0-3 3v9a3 3 0 0 0 3 3h8.25a3 3 0 0 0 3-3v-9a3 3 0 0 0-3-3H4.5zM19.94 18.75l-2.69-2.69V7.94l2.69-2.69c.944-.945 2.56-.276 2.56 1.06v11.38c0 1.336-1.616 2.005-2.56 1.06z",
    // Meet's glyph only fills the middle ~63% of its 24x24 viewBox vertically, so
    // scale it up to visually match the full-bleed GitHub/LinkedIn marks. The wrapper
    // grows to match, keeping the gap to neighboring icons even.
    iconClass: "scale-150",
    wrapperClass: "h-6 w-6",
  },
];
---

<footer id="contact" class="border-t border-border bg-surface">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row"
  >
    <p class="text-xs text-text-muted">
      &copy; <span id="copyright-year">{year}</span> {t("footer.rights")}
    </p>

    <div class="flex items-center gap-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            title={link.label}
            data-social-platform={link.label}
            class={`flex items-center justify-center text-text-muted transition-colors hover:text-accent ${link.wrapperClass ?? "h-4 w-4"}`}
            target="_blank"
            rel="noreferrer"
          >
            <svg
              class={`h-4 w-4 ${link.iconClass ?? ""}`}
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={link.icon} />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</footer>

<script>
  // Re-derive the year on the client so a static build doesn't go stale at year-end.
  const el = document.getElementById("copyright-year");
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-social-platform]').forEach((link) => {
      link.addEventListener('click', () => {
        window.posthog?.capture('social_link_clicked', {
          platform: link.getAttribute('data-social-platform'),
          href: link.getAttribute('href'),
        });
      });
    });
  });
</script>
