---
import { useTranslations, getLocale } from "../../i18n/utils";

const t = useTranslations(getLocale(Astro.currentLocale));
---

<section id="about" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="text-2xl font-bold text-text sm:text-3xl">{t("about.title")}</h2>
  <p class="mt-4 max-w-3xl text-text-muted">{t("about.body")}</p>
</section>