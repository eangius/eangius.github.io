---
import { useTranslations, getLocale } from "../../i18n/utils";

const t = useTranslations(getLocale(Astro.currentLocale));
---

{/*
  Pagefind generates /pagefind/* during the postbuild step (see package.json).
  These files don't exist in `astro dev`, so the search box is inert until you
  run `npm run build`.
*/}
<div id="search" class="pagefind-search w-full max-w-xs"></div>
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline define:vars={{ placeholder: t("search.placeholder") }}>
  // @ts-nocheck
  window.addEventListener("DOMContentLoaded", () => {
    if (typeof window.PagefindUI === "function") {
      new window.PagefindUI({
        element: "#search",
        showSubResults: false,
        translations: { placeholder },
      });
    }
  });
</script>

<style>
  /* Make the Pagefind UI follow our theme tokens */
  .pagefind-search {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-font: var(--font-sans);
  }

  /* Replace the OS-dependent default focus ring (can render black/gray
     depending on the system accent color) by recoloring the existing
     border to the theme accent — same dimensions, just highlighted */
  .pagefind-search :global(.pagefind-ui__search-input:focus-visible) {
    outline: none;
    border-color: var(--color-accent);
  }

  /* Float the results below the input instead of widening the header */
  .pagefind-search :global(.pagefind-ui__drawer) {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 60;
    width: max(20rem, 100%);
    max-height: 70vh;
    overflow-y: auto;
    margin-top: 0.5rem;
    padding: 0 1rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
  }
</style>
