---
import BaseLayout from "./BaseLayout.astro";
import { useTranslations, getLocale } from "../i18n/utils";

interface Props {
  title: string;
  summary: string;
  thumbnail?: string;
  tags?: string[];
  repoUrl?: string;
  demoUrl?: string;
}

const { title, summary, thumbnail, tags = [], repoUrl, demoUrl } = Astro.props;

const lang = getLocale(Astro.currentLocale);
const t = useTranslations(lang);
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-8 border-b border-border pb-6">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <div class="flex-1">
          <h1 class="text-3xl font-bold text-text">{title}</h1>
          <p class="mt-2 text-text-muted">{summary}</p>

          {
            tags.length > 0 && (
              <ul class="mt-4 flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <li class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-500">
                    {tag}
                  </li>
                ))}
              </ul>
            )
          }

          <div class="mt-4 flex gap-4">
            {
              repoUrl && (
                <a
                  href={repoUrl}
                  id="project-repo-link"
                  target="_blank"
                  rel="noreferrer"
                  class="text-sm font-semibold text-accent hover:text-accent-hover"
                >
                  {t("projects.viewRepo")}
                </a>
              )
            }
            {
              demoUrl && (
                <a
                  href={demoUrl}
                  id="project-demo-link"
                  target="_blank"
                  rel="noreferrer"
                  class="text-sm font-semibold text-accent hover:text-accent-hover"
                >
                  {t("projects.viewDemo")}
                </a>
              )
            }
          </div>
        </div>

        {
          thumbnail && (
            <img
              src={thumbnail}
              alt=""
              width="400"
              height="240"
              class="w-full rounded-lg object-cover sm:w-56 sm:flex-shrink-0 lg:w-72"
            />
          )
        }
      </div>
    </header>

    <div class="prose prose-neutral max-w-none dark:prose-invert">
      <slot />
    </div>
  </article>
</BaseLayout>

<script is:inline define:vars={{ projectTitle: title, projectTags: tags, projectSlug: Astro.url.pathname }}>
  document.addEventListener('DOMContentLoaded', () => {
    window.posthog?.capture('project_viewed', {
      project_title: projectTitle,
      project_tags: projectTags,
      project_slug: projectSlug,
    });

    document.getElementById('project-repo-link')?.addEventListener('click', () => {
      window.posthog?.capture('project_repo_clicked', {
        project_title: projectTitle,
        project_slug: projectSlug,
      });
    });

    document.getElementById('project-demo-link')?.addEventListener('click', () => {
      window.posthog?.capture('project_demo_clicked', {
        project_title: projectTitle,
        project_slug: projectSlug,
      });
    });
  });
</script>
